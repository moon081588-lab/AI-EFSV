# AI-EFSV — AI services configuration
# Copy this file to .env and fill in your values.
# The .env file is gitignored and never committed.

# ── Enable AI ────────────────────────────────────────────────────────────────
# Set to true to enable real AI for C1 matching, C2 prioritization, and
# C3 report drafting. When false (default), all three fall back to
# deterministic rule-based logic.
AI_ENABLED=true

# ── Provider ─────────────────────────────────────────────────────────────────
# "ollama" for a local Ollama server.
# Any OpenAI-compatible server also works (e.g. LM Studio, vLLM, OpenAI).
AI_PROVIDER=ollama

# Base URL of the OpenAI-compatible chat/completions endpoint.
# Ollama default (no trailing slash):
AI_BASE_URL=http://127.0.0.1:11434/v1

# API key — leave blank for Ollama (no key required).
# Set to your key for OpenAI or other hosted providers.
AI_API_KEY=

# ── Model names ──────────────────────────────────────────────────────────────
# All three tasks can share one model. Recommended for local use:
#   llama3.2         — 3 B params, fast on any Mac, good JSON output
#   llama3.1:8b      — better quality, needs 16 GB+ RAM
#   qwen2.5:7b       — excellent structured-output compliance
#
# Pull your chosen model first:
#   ollama pull llama3.2
#
# C1: requirement-to-test-case matching
MODEL_C1_MATCHING=llama3.2

# C2: regression test prioritization scoring
MODEL_C2_PRIORITIZER=gemma3:4b

# C3b: compliance report section drafting
MODEL_C3_REPORT=llama3.2

# ── Timeout ───────────────────────────────────────────────────────────────────
# Seconds to wait for a single model response. Local inference can be slow;
# 120 s is a reasonable starting point. Increase if you see timeout fallbacks.
AI_TIMEOUT_SECONDS=120

# ── Chronos anomaly service (separate — leave disabled unless you set it up) ──
# The C3 anomaly detector is a separate FastAPI service that runs a
# Chronos time-series model. Leave CHRONOS_ENABLED=false to use the built-in
# statistical fallback instead.
CHRONOS_ENABLED=false
CHRONOS_BASE_URL=http://127.0.0.1:9001/anomaly
CHRONOS_MODEL_NAME=amazon/chronos-bolt-small
